#
# Example .env file for MCC-Web
# Copy this file to .env and adjust the values for your environment
#
# Production: Place .env in /data/appl/mcc/.env
# Development: Place .env in the project root (mcc-web/.env)

# =============================================================================
# Django Core Settings
# =============================================================================

# SECURITY WARNING: keep the secret key used in production secret!
# Generate a new secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-YOUR_SECRET_KEY_HERE

# SECURITY WARNING: don't run with debug turned on in production!
DEBUG=True

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=mycyclingcity.net,127.0.0.1

# Comma-separated list of trusted origins for CSRF protection
CSRF_TRUSTED_ORIGINS=https://mycyclingcity.net

# Public project portal URL (Info hub link in map/game)
PROJECT_PORTAL_URL=https://adfc-tk.de/mycyclingcity

# Session and CSRF cookie security (automatically set based on DEBUG if not specified)
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# =============================================================================
# Minecraft Integration
# =============================================================================

# RCON Connection Settings
MCC_MINECRAFT_RCON_HOST=127.0.0.1
MCC_MINECRAFT_RCON_PORT=25575
MCC_MINECRAFT_RCON_PASSWORD=your-rcon-password-here

# Scoreboard Objective Names (team spendable only)
MCC_MINECRAFT_SCOREBOARD_TEAM_SPENDABLE=team_velos_spendable
MCC_MINECRAFT_SCOREBOARD_TEAM_DISPLAY_NAME_DEFAULT=Velo-Arena
MCC_MINECRAFT_SCOREBOARD_DISPLAY_SLOT=sidebar

# Legacy (deprecated, kept for compatibility)
MCC_MINECRAFT_SCOREBOARD_COINS_TOTAL=player_coins_total
MCC_MINECRAFT_SCOREBOARD_COINS_SPENDABLE=player_coins_spendable
MCC_MINECRAFT_SCOREBOARD_GROUP_VELOS_TOTAL=group_velos_total
MCC_MINECRAFT_SCOREBOARD_GROUP_VELOS_SPENDABLE=group_velos_spendable

# Worker Configuration
# MCC_MINECRAFT_WORKER_POLL_INTERVAL=1  # Deprecated: Only used as fallback
# Deprecated (unused): previously caused blind 30s sleeps that dropped socket notifies
MCC_MINECRAFT_WORKER_FALLBACK_POLL_INTERVAL=30
# Seconds to wait on notify socket before re-polling outbox (keep socket listening)
MCC_MINECRAFT_WORKER_SOCKET_TIMEOUT=5.0
MCC_MINECRAFT_RCON_HEALTH_INTERVAL=30
MCC_MINECRAFT_SNAPSHOT_INTERVAL=60
MCC_MINECRAFT_SNAPSHOT_UPDATE_DB_SPENDABLE=True

# Outbox Configuration
MCC_MINECRAFT_OUTBOX_DONE_TTL_DAYS=7
MCC_MINECRAFT_OUTBOX_FAILED_TTL_DAYS=30
MCC_MINECRAFT_OUTBOX_MAX_EVENTS=50000

# WebSocket Configuration (optional, Daphne on MCC_MINECRAFT_WS_PORT)
MCC_MINECRAFT_WS_ENABLED=False
MCC_MINECRAFT_WS_SHARED_SECRET=SECRET
MCC_MINECRAFT_WS_ALLOWED_SERVER_IDS=
MCC_MINECRAFT_WS_BIND_HOST=0.0.0.0
MCC_MINECRAFT_WS_PORT=8002
# Optional: explicit host for MCC-Bridge URL (else IP from ALLOWED_HOSTS, then DNS)
# MCC_MINECRAFT_WS_PUBLIC_HOST=192.168.90.2
# Assign LuckPerms groups automatically when registering teams in MCC Admin
MCC_MINECRAFT_LP_SYNC_ENABLED=True
MCC_MINECRAFT_LP_GROUP_PREFIX=team_

# Optional: direct import from MC server filesystem (shop push still uses MCC-Bridge)
# MCC_MINECRAFT_ESGUI_SHOPS_DIR=/data/games/minecraft_server/plugins/EconomyShopGUI/shops
# MCC_MINECRAFT_ESGUI_SECTIONS_DIR=/data/games/minecraft_server/plugins/EconomyShopGUI/sections

# =============================================================================
# API Configuration
# =============================================================================

# API Key for device authentication
MCC_APP_API_KEY=MCC-APP-API-KEY-SECRET

# Health Check API Keys (comma-separated for multiple keys)
# HEALTH_CHECK_API_KEYS=key1,key2,key3

# =============================================================================
# Game Configuration
# =============================================================================

# Coin conversion factor (kilometers to coins)
DEFAULT_COIN_CONVERSION_FACTOR=100

# =============================================================================
# Kiosk Configuration
# =============================================================================

# Update intervals in seconds (synchronized with cronjob)
MCC_KIOSK_TICKER_UPDATE_INTERVAL=60
MCC_KIOSK_BANNER_UPDATE_INTERVAL=60
MCC_KIOSK_CONTENT_UPDATE_INTERVAL=60
MCC_KIOSK_FOOTER_UPDATE_INTERVAL=60


